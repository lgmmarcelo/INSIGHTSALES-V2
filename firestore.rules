rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
        // God-mode for the founder to prevent any bootstrap lockouts
        allow read, write: if request.auth != null && request.auth.token.email == 'marcelo@laghettomultipropriedade.com.br';
        allow read, write: if false;
    }

    // Primitives
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { 
        return id is string && id.size() > 0 && id.size() <= 128; 
    }

    // A user exists if they are in the users collection
    function isRegisteredUser() {
        return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // Role-Based Access Control via `users` collection lookup
    function getUserRole() {
        // Use ternary to prevent calling get() on a non-existent document, which throws a rules evaluation error
        return isRegisteredUser() ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role : 'none';
    }

    function isAdmin() {
        return getUserRole() == 'admin';
    }

    function isAnalyst() {
        return getUserRole() == 'analyst';
    }

    function isViewer() {
        return getUserRole() == 'viewer';
    }

    // Role-based Access Control for Custom Profiles
    function hasPermission(perm) {
        let role = getUserRole();
        return role == 'admin' || 
               (role != 'viewer' && role != 'analyst' && role != 'none' && 
                exists(/databases/$(database)/documents/access_profiles/$(role)) &&
                perm in get(/databases/$(database)/documents/access_profiles/$(role)).data.permissions);
    }

    // --- Entity Blueprint Validation ---

    function isValidUser(data) {
        return data.keys().hasAll(['email', 'role', 'createdAt']) && 
               data.email is string && data.email.size() <= 200 &&
               data.role is string && data.role.size() <= 60 &&
               data.createdAt is number;
    }

    function isValidSale(data) {
        // Enforcing core keys. Optional columns and manual input columns are omitted from hasAll
        return data.keys().hasAll([
                 'localizador', 'dataAtendimento', 'cpf', 'statusContrato', 'uploadedAt'
               ]) &&
               data.localizador is string && data.localizador.size() <= 100 &&
               data.dataAtendimento is string && data.dataAtendimento.size() <= 20 &&
               data.cpf is string && data.cpf.size() <= 20 &&
               data.statusContrato is string && data.statusContrato.size() <= 60 &&
               data.uploadedAt is number;
    }

    // --- Path Rules ---

    match /users/{userId} {
        // Admins and those with user config permissions can list all users
        allow list: if isAdmin() || hasPermission('view_usuarios');
        
        // A user can always read their own profile, or admins/managers can read
        allow get: if (request.auth != null && request.auth.uid == userId) || isAdmin() || hasPermission('view_usuarios');

        // Creating their own bootstrap user document
        allow create: if request.auth != null && request.auth.uid == userId && 
            incoming().email == 'marcelo@laghettomultipropriedade.com.br' && 
            incoming().role == 'admin';

        // Admins and Managers can create users
        allow create: if (isAdmin() || hasPermission('view_usuarios')) && isValidUser(incoming());

        // UPDATE - Admins and Managers
        allow update: if isValidId(userId) && isValidUser(incoming()) && (isAdmin() || hasPermission('view_usuarios')) &&
            incoming().diff(existing()).affectedKeys().hasOnly(['role', 'displayName', 'senhaProvisoria', 'updatedAt']);

        // DELETE
        allow delete: if isValidId(userId) && (isAdmin() || hasPermission('view_usuarios'));
    }

    match /access_profiles/{profileId} {
        allow read: if isSignedIn();
        allow write: if isAdmin() || hasPermission('view_perfis');
    }

    match /sales/{saleId} {
        // Read: Any registered user (Admin, Analyst, Viewer)
        allow list: if isRegisteredUser();
        allow get: if isValidId(saleId) && isRegisteredUser();

        // Create: Admin or users with db_upload or edit_atendimentos permission
        allow create: if isValidId(saleId) && isValidSale(incoming()) && (isAdmin() || isAnalyst() || hasPermission('db_upload') || hasPermission('edit_atendimentos'));

        // Update: Admin, Analyst or those with edit/override permissions
        allow update: if isValidId(saleId) && isValidSale(incoming()) && (isAdmin() || isAnalyst() || hasPermission('edit_atendimentos') || hasPermission('override_atendimentos') || hasPermission('db_upload'));

        // Delete: Admin or those with db_delete or clear_atendimentos
        allow delete: if isValidId(saleId) && (isAdmin() || hasPermission('db_delete') || hasPermission('clear_atendimentos'));
    }
  }
}
