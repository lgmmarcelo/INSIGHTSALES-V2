rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
        allow read, write: if false;
    }

    // Primitives
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { 
        return id is string && id.size() > 0 && id.size() <= 128; 
    }

    // A user exists if they are in the users collection
    function isRegisteredUser() {
        let uid = request.auth != null ? request.auth.uid : 'anonymous';
        return request.auth != null && exists(/databases/$(database)/documents/users/$(uid));
    }

    // Role-Based Access Control via `users` collection lookup
    function getUserRole() {
        // Use safe check for role field to prevent evaluation errors
        let uid = request.auth != null ? request.auth.uid : 'anonymous';
        let userDocPath = /databases/$(database)/documents/users/$(uid);
        let hasUser = isRegisteredUser();
        let docData = hasUser ? get(userDocPath).data : {};
        return ('role' in docData) ? docData.role : 'none';
    }

    function isAdmin() {
        return getUserRole() == 'admin';
    }

    function isAnalyst() {
        return getUserRole() == 'analyst';
    }

    function isViewer() {
        return getUserRole() == 'viewer';
    }

    // Role-based Access Control for Custom Profiles
    function hasPermission(perm) {
        let uid = request.auth != null ? request.auth.uid : 'anonymous';
        let userDocPath = /databases/$(database)/documents/users/$(uid);
        let hasUserDoc = exists(userDocPath);
        let userDocData = hasUserDoc ? get(userDocPath).data : {};
        let role = ('role' in userDocData) ? userDocData.role : 'none';
        let userPerms = ('permissions' in userDocData && userDocData.permissions is list) ? userDocData.permissions : [];
        
        let profilePath = /databases/$(database)/documents/access_profiles/$(role);
        // Only attempt to check profile if role is not one of the built-ins and role holds a string
        let hasProfile = (role is string && role != 'viewer' && role != 'analyst' && role != 'admin' && role != 'none') && exists(profilePath);
        let profileData = hasProfile ? get(profilePath).data : {};
        let profilePerms = ('permissions' in profileData && profileData.permissions is list) ? profileData.permissions : [];
        
        return role == 'admin' || 
               userPerms.hasAny([perm]) || 
               (hasProfile && profilePerms.hasAny([perm]));
    }

    // --- Entity Blueprint Validation ---

    function isValidUser(data) {
        return data.keys().hasAll(['email', 'role', 'createdAt']) && 
               data.email is string && data.email.size() <= 200 &&
               data.role is string && data.role.size() <= 60 &&
               data.createdAt is number;
    }

    function isValidSale(data) {
        // Enforcing core keys. Optional columns and manual input columns are omitted from hasAll.
        // We removed uploadedAt and dataAtendimento from the strict list to allow updating older imported rows.
        return data.keys().hasAll([
                 'localizador', 'cpf', 'statusContrato'
               ]) &&
               data.localizador is string && data.localizador.size() <= 100 &&
               data.cpf is string && data.cpf.size() <= 30 &&
               data.statusContrato is string && data.statusContrato.size() <= 60;
    }

    // --- Path Rules ---

    match /users/{userId} {
        // Any signed in user can list and read users (needed for assigning analysts in dropdowns)
        allow read: if request.auth != null;

        // Creating their own bootstrap user document
        allow create: if request.auth != null && request.auth.uid == userId && 
            incoming().email == 'marcelo@laghettomultipropriedade.com.br' && 
            incoming().role == 'admin';

        // Admins and Managers can create users
        allow create: if (isAdmin() || hasPermission('view_usuarios')) && isValidUser(incoming());

        // UPDATE - Admins and Managers
        allow update: if isValidId(userId) && isValidUser(incoming()) && (isAdmin() || hasPermission('view_usuarios')) &&
            incoming().diff(existing()).affectedKeys().hasOnly(['role', 'displayName', 'senhaProvisoria', 'updatedAt', 'roleName', 'permissions']);

        // DELETE
        allow delete: if isValidId(userId) && (isAdmin() || hasPermission('view_usuarios'));
    }

    match /access_profiles/{profileId} {
        allow read: if isSignedIn();
        allow write: if isAdmin() || hasPermission('view_perfis');
    }

    match /sales/{saleId} {
        // Read: Any registered user (Admin, Analyst, Viewer)
        allow list: if isRegisteredUser();
        allow get: if isValidId(saleId) && isRegisteredUser();

        // Create: Admin or users with db_upload or edit_atendimentos permission
        allow create: if isValidId(saleId) && isValidSale(incoming()) && (isAdmin() || isAnalyst() || hasPermission('db_upload') || hasPermission('edit_atendimentos'));

        // Update: Admin, Analyst or those with edit/override permissions
        allow update: if isValidId(saleId) && (isAdmin() || isAnalyst() || hasPermission('edit_atendimentos') || hasPermission('override_atendimentos') || hasPermission('db_upload'));

        // Delete: Admin or those with db_delete or clear_atendimentos
        allow delete: if isValidId(saleId) && (isAdmin() || hasPermission('db_delete') || hasPermission('clear_atendimentos'));
    }
  }
}
